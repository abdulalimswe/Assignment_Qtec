PORT=5000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Option 1 – Full connection URL (required for SSL / cloud DBs such as Render)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option 2 – Individual vars (used when DATABASE_URL is not set)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=quickhire
PG_USER=postgres
PG_PASSWORD=your_password

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# Set this on Vercel to your deployed frontend URL.
# CORS_ORIGIN=https://your-frontend.vercel.app
