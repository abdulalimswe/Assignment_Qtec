PORT=5000
NODE_ENV=development

# Option 1: Full connection URL (takes priority, required for SSL / Render / cloud DBs)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option 2: Individual connection vars (used when DATABASE_URL is not set)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=quickhire
PG_USER=postgres
PG_PASSWORD=your_password
